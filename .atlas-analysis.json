  "keyFeatures": [
    "Automatic context injection at session start",
    "Per-file summaries with auto-update on edits",
    "Decision and architecture logging",
    "Global and project-level stash scopes",
    "Full repository scanning with --force flag"
  ],
  "publicApiSurface": [
    "/stash-save - Save session summary with decisions and architecture",
    "/stash-scan - Index entire repository and create summaries",
    "/stash-scan --force - Re-scan all files and overwrite existing summaries",
    "/stash-clear - Wipe project stash after confirmation",
    "SessionStart hook - Injects stash context automatically",
    "PostToolUse hook - Triggers auto-update after file edits"
